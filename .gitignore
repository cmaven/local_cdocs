# ============================================================
# .gitignore: local_cdocs — 빌드 산출물/의존성/내부상태/개인정보 제외
# 생성일: 2026-06-22
# ============================================================

# 의존성
node_modules/

# 빌드 산출물 (electron-builder)
dist/

# VitePress 빌드 캐시/산출물 (재생성됨)
**/.vitepress/cache/
**/.vitepress/dist/

# OMC 내부 세션 상태 (절대경로/세션명/비용 등 개인정보 포함 → 커밋 금지)
.omc/

# 상태 점검용 스크린샷
status_*.png

# CI 빌드 시 생성되는 빌드 정보 파일 (로컬 dev 환경에서 실수로 커밋 방지)
electron/build-info.json

# 로그/임시
*.log
*.tgz
.DS_Store
Thumbs.db

# 보안 (혹시 모를 환경/시크릿 파일)
.env
.env.*
*.pem
*.key

# Claude Code 하니스 내부 파일
.claude/
